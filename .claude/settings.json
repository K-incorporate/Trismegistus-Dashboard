{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-changed.mjs\"",
            "timeout": 60,
            "statusMessage": "Linting changed file..."
          }
        ]
      }
    ]
  }
}
